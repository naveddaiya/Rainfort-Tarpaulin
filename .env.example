# Firebase Configuration
# Get these values from your Firebase Console: https://console.firebase.google.com/
# 1. Go to Project Settings > General
# 2. Scroll down to "Your apps" section
# 3. Click on the web app or create one
# 4. Copy the configuration values here

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Razorpay (payment gateway)
# Get from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_xxxx for test mode, rzp_live_xxxx for production
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Cloudinary (product image uploads — free tier, no billing required)
# 1. Sign up at https://cloudinary.com (free)
# 2. Cloud name: Dashboard → top-left
# 3. Upload preset: Settings → Upload → Upload presets → Add preset → Signing mode: Unsigned
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset-name
